{
  "expo": {
    "name": "Registro Fotográfico de Obra",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D47A1"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.tapia.registrofotograficodeobra",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Feather.ttf"
          ]
        }
      ],
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "O aplicativo precisa da câmera para registrar fotos da obra."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O aplicativo precisa acessar suas fotos para importar imagens da obra."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "8e173fe8-ac27-4c4e-b0e3-549124bfe9b9"
      }
    }
  }
}
